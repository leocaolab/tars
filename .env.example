# Optional environment variables for tars CLI / library.
#
# tars itself reads its config from `~/.tars/config.toml` (or
# `--config <path>` / `TARS_CONFIG=<path>`). Provider API keys are
# referenced from the TOML by name; the actual values live in env
# vars so secrets don't end up checked into config files.
#
# Set whichever providers you intend to use. The names below match
# the built-in provider table — see `tars init` for the starter
# config that wires them up.

# Anthropic Claude (claude-sonnet-4-5, claude-opus, ...)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (gpt-4o, gpt-4o-mini, o1, ...)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (gemini-2.5-pro, gemini-2.0-flash, ...)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local OpenAI-compatible servers (vLLM / llama.cpp / LM Studio).
# These typically don't need a real key — set anything truthy so the
# adapter doesn't refuse to start.
# VLLM_API_KEY=local
# LLAMACPP_API_KEY=local

# tars-cli runtime overrides (rarely needed)
# TARS_CONFIG=/custom/path/to/config.toml
# RUST_LOG=tars_pipeline=debug,tars_provider=info
